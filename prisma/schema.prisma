generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id            String    @id @default(cuid())
  channel       Channel
  channelId     String    // ID del contacto en la plataforma (phone E.164, psid, ig_id)
  userType      UserType?
  contactName   String?
  botPaused     Boolean   @default(false)
  stage         String    @default("NUEVO")  // NUEVO | PENDIENTE | AGENDADO
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages Message[]

  @@unique([channel, channelId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  waMessageId    String?     // ID único de Meta para deduplicación
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

enum Channel {
  WHATSAPP
  FACEBOOK
  INSTAGRAM
}

enum UserType {
  PACIENTE
  PROFESIONAL
  UNKNOWN
}

enum MessageRole {
  USER
  BOT
  OPERATOR
}
