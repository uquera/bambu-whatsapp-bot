# ─── BASE DE DATOS ──────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
# Producción: DATABASE_URL="file:/var/www/bambu-whatsapp-bot/prisma/prod.db"

# ─── CLAUDE API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── META / WHATSAPP BUSINESS CLOUD API ─────────────────────────────────────
# System User Access Token (permanente) — Meta Business Suite → System Users
WHATSAPP_TOKEN="EAAG..."

# Phone Number ID del número registrado — NO es el número de teléfono en sí
WHATSAPP_PHONE_NUMBER_ID="123456789012345"

# Token de verificación del webhook — cualquier string secreto que elijas
WHATSAPP_VERIFY_TOKEN="bambu_webhook_secret_2024"
