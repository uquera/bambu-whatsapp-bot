# ─── BASE DE DATOS ──────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
# Producción: DATABASE_URL="file:/var/www/bambu-whatsapp-bot/prisma/prod.db"

# ─── CLAUDE API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── META / WHATSAPP BUSINESS CLOUD API ─────────────────────────────────────
# System User Access Token (permanente) — Meta Business Suite → System Users
WHATSAPP_TOKEN="EAAG..."

# Phone Number ID del número registrado — NO es el número de teléfono en sí
WHATSAPP_PHONE_NUMBER_ID="123456789012345"

# Token de verificación del webhook — mismo valor configurado en Meta Developer Console
WHATSAPP_VERIFY_TOKEN="bambu_webhook_secret_2024"

# ─── META / FACEBOOK MESSENGER ──────────────────────────────────────────────
# Page Access Token — Meta Developer Console → Messenger → Settings → Page Access Tokens
FACEBOOK_PAGE_ACCESS_TOKEN="EAAG..."

# ─── META / INSTAGRAM DIRECT MESSAGES ──────────────────────────────────────
# Si la cuenta IG está vinculada a la página FB, puede ser el mismo token que Facebook
INSTAGRAM_PAGE_ACCESS_TOKEN="EAAG..."

# ─── INTEGRACIÓN CON CENTRO BAMBU DEMO ──────────────────────────────────────
# URL de la API interna del proyecto centro-bambu-demo
CENTRO_BAMBU_API_URL="http://localhost:3001"

# Clave compartida entre ambos proyectos — debe ser la misma en centro-bambu-demo
BOT_INTERNAL_KEY="secreto-compartido-cambiar-en-produccion"

# ─── DASHBOARD CRM ──────────────────────────────────────────────────────────
# Contraseña para acceder al dashboard — si no se define, el dashboard es público (solo dev)
DASHBOARD_SECRET="cambia-esta-clave-en-produccion"

# ─── BRANDING ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BOT_NAME="Bambú"
NEXT_PUBLIC_BOT_EMOJI="🌿"
